# Copy to .env and fill in to enable the Claude-powered (online) assistant.
# Without a key the app still runs in deterministic OFFLINE mode (tool output only).
ANTHROPIC_API_KEY=

# Optional: override the model (default: claude-sonnet-5).
# Alternatives: claude-opus-4-8 (stronger reasoning), claude-haiku-4-5 (cheapest/fastest).
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: override the dataset directory (defaults to ../data).
# EQUITIE_DATA_DIR=/absolute/path/to/data
